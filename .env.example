# Primary database connection used by Prisma and the app.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fairway_match"

# Required for admin login in production.
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Public canonical URL for scorecard links, invites, and admin-generated links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional unless you want live course lookup.
GOLF_COURSE_API_KEY=""

# Optional provider toggles used by course import scripts.
DISABLED_UNLICENSED_SOURCES="false"
USGA_LOOKUP_SCRIPT=""
