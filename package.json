{
  "name": "the-two-man",
  "version": "0.1.0",
  "private": false,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "courses:import:illinois": "tsx scripts/import_illinois_courses.ts",
    "bracket:preview:stage": "tsx scripts/stage_bracket_preview.ts",
    "dry-run:tournament": "tsx scripts/dry_run_tournament.ts",
    "tournament:reset:state": "tsx scripts/reset_tournament_state.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "clsx": "^2.1.1",
    "ghin": "^0.7.0",
    "nanoid": "^5.1.5",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "description": "Mobile-first tournament operating system for season-long two-man net better-ball match play.",
  "license": "MIT",
  "keywords": [
    "golf",
    "tournament",
    "nextjs",
    "prisma",
    "match-play",
    "scoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jcb79107/the-two-man.git"
  },
  "homepage": "https://github.com/jcb79107/the-two-man",
  "bugs": {
    "url": "https://github.com/jcb79107/the-two-man/issues"
  }
}
